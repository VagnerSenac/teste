programa {
  funcao inicio() {
    //leia dois numeros  e informe se eles são iguais ou diferentes.
    real n1,n2
    escreva ("digite um numero : ")
    leia (n1)
    escreva ("digite outro numero: ")
    leia (n2)
    se (n1==n2) {
      escreva ("esses numeros são iguais")

    }
  senao {
    escreva ("esses numeros não são iguais")
  }
  }
}
